FROM node:22-bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ffmpeg \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json tsconfig.json tsconfig.worker.json ./
RUN npm ci

COPY lib ./lib
COPY worker ./worker
RUN npm run build:worker

CMD ["npm", "run", "worker"]
