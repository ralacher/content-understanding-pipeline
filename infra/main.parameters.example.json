{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "storageAccountName": {
      "value": "yourstorageacct"
    },
    "cosmosAccountName": {
      "value": "yourcosmosacct"
    },
    "cosmosLocation": {
      "value": "westus3"
    },
    "contentUnderstandingAccountName": {
      "value": "yourcontentunderstandingacct"
    },
    "webAppName": {
      "value": "your-content-understanding-webapp"
    },
    "webContainerImage": {
      "value": "myregistry.azurecr.io/content-understanding-web:latest"
    },
    "workerContainerImage": {
      "value": "myregistry.azurecr.io/content-understanding-worker:latest"
    },
    "containerRegistryName": {
      "value": "yourregistry"
    },
    "containerRegistryLoginServer": {
      "value": "yourregistry.azurecr.io"
    },
    "aiSearchSku": {
      "value": "basic"
    },
    "appTitle": {
      "value": "Content Understanding Hub"
    },
    "contentUnderstandingAnalyzerUrl": {
      "value": "https://your-content-understanding-account.services.ai.azure.com/contentunderstanding/analyzers/yourAnalyzerName?api-version=2025-11-01"
    },
    "existingContainerAppsVnetName": {
      "value": ""
    },
    "existingContainerAppsSubnetName": {
      "value": ""
    },
    "existingContainerAppsVnetResourceGroup": {
      "value": ""
    },
    "containerAppsVnetName": {
      "value": "content-understanding-env-vnet"
    },
    "containerAppsVnetAddressPrefix": {
      "value": "10.240.0.0/16"
    },
    "containerAppsInfrastructureSubnetName": {
      "value": "infrastructure"
    },
    "containerAppsInfrastructureSubnetAddressPrefix": {
      "value": "10.240.0.0/24"
    },
    "uploadWriteQueueMessage": {
      "value": true
    },
    "authClientId": {
      "value": ""
    },
    "authClientSecret": {
      "value": ""
    },
    "authTenantId": {
      "value": ""
    },
    "authSessionSecret": {
      "value": ""
    }
  }
}
